{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":disableDependencyDashboard"
  ],
  "enabledManagers": ["flux", "helm-values", "dockerfile", "kubernetes", "custom.regex"],
  "timezone": "UTC",
  "labels": ["dependencies", "renovate"],
  "commitMessagePrefix": "chore(deps):",
  "ignorePaths": ["kubernetes/clusters/production/flux-system/**"],

  "separateMajorMinor": true,
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true,
    "automergeType": "pr",
    "rebaseWhen": "conflicted",
    "automergeSchedule": ["at any time"]
  },

  "packageRules": [
    {
      "description": "Keep Jellyfin on stable semver tags",
      "matchDatasources": ["docker"],
      "matchDepNames": ["linuxserver/jellyfin"],
      "matchPackageNames": ["linuxserver/jellyfin", "lscr.io/linuxserver/jellyfin"],
      "allowedVersions": "/^\\d+\\.\\d+\\.\\d+$/"
    },
    {
      "description": "Keep Tautulli on stable semver tags",
      "matchDatasources": ["docker"],
      "matchDepNames": ["linuxserver/tautulli"],
      "matchPackageNames": ["linuxserver/tautulli", "lscr.io/linuxserver/tautulli"],
      "allowedVersions": "/^\\d+\\.\\d+\\.\\d+$/"
    },
    {
      "description": "Keep Lidarr on the deployed 3.x semver line",
      "matchDatasources": ["docker"],
      "matchDepNames": ["linuxserver/lidarr"],
      "matchPackageNames": ["linuxserver/lidarr", "lscr.io/linuxserver/lidarr"],
      "allowedVersions": "/^3\\.\\d+\\.\\d+$/"
    },
    {
      "description": "Keep Alpine on stable semver tags",
      "matchDatasources": ["docker"],
      "matchDepNames": ["library/alpine"],
      "matchPackageNames": ["library/alpine", "docker.io/library/alpine"],
      "allowedVersions": "/^\\d+\\.\\d+\\.\\d+$/"
    },
    {
      "description": "Keep BusyBox on stable semver tags",
      "matchDatasources": ["docker"],
      "matchDepNames": ["library/busybox"],
      "matchPackageNames": ["library/busybox", "docker.io/library/busybox"],
      "allowedVersions": "/^\\d+\\.\\d+\\.\\d+$/"
    },
    {
      "description": "Keep Apache Tika on stable semver tags",
      "matchDatasources": ["docker"],
      "matchDepNames": ["apache/tika"],
      "matchPackageNames": ["apache/tika", "docker.io/apache/tika"],
      "allowedVersions": "/^\\d+\\.\\d+\\.\\d+\\.\\d+$/"
    },
    {
      "description": "Keep Frigate on stable semver tags",
      "matchDatasources": ["docker"],
      "matchDepNames": ["blakeblackshear/frigate"],
      "matchPackageNames": ["blakeblackshear/frigate", "ghcr.io/blakeblackshear/frigate"],
      "allowedVersions": "/^\\d+\\.\\d+\\.\\d+$/"
    },
    {
      "description": "Keep LibreChat RAG API on release semver tags",
      "matchDatasources": ["docker"],
      "matchDepNames": ["danny-avila/librechat-rag-api-dev-lite"],
      "matchPackageNames": [
        "danny-avila/librechat-rag-api-dev-lite",
        "registry.librechat.ai/danny-avila/librechat-rag-api-dev-lite"
      ],
      "versioning": "semver",
      "allowedVersions": "/^v\\d+\\.\\d+\\.\\d+$/"
    },
    {
      "description": "Global stability and automerge schedule",
      "matchUpdateTypes": ["minor", "patch", "digest"],
      "minimumReleaseAge": "5 days",
      "matchCurrentVersion": "!/^0/",
      "automerge": true,
      "automergeType": "pr",
      "rebaseWhen": "conflicted",
      "automergeSchedule": ["at any time"]
    },
    {
      "description": "Kubernetes major updates require manual review",
      "matchPaths": ["kubernetes/**"],
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "automergeType": "pr"
    },
    {
      "description": "Kubernetes minor/patch updates auto-merge immediately",
      "matchPaths": ["kubernetes/**"],
      "matchUpdateTypes": ["minor", "patch", "digest"],
      "matchCurrentVersion": "!/^0/",
      "automerge": true,
      "platformAutomerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash",
      "rebaseWhen": "conflicted",
      "automergeSchedule": ["at any time"]
    },
    {
      "description": "Kubernetes 0.x updates auto-merge after stability checks",
      "matchPaths": ["kubernetes/**"],
      "matchUpdateTypes": ["minor", "patch", "digest"],
      "matchCurrentVersion": "/^0/",
      "minimumReleaseAge": "5 days",
      "automerge": true,
      "platformAutomerge": true,
      "automergeType": "pr",
      "rebaseWhen": "conflicted",
      "automergeSchedule": ["at any time"]
    },
    {
      "description": "Group Observability Stack",
      "matchPackageNames": ["/loki/", "/alloy/", "/kube-prometheus-stack/"],
      "groupName": "observability"
    },
    {
      "description": "Group Networking tools",
      "matchPackageNames": ["/traefik/", "/metallb/", "/external-dns/"],
      "groupName": "networking"
    },
    {
      "description": "Manual review for Major updates or 0.x.x (unstable) apps",
      "matchUpdateTypes": ["major"],
      "matchCurrentVersion": "/^0/",
      "automerge": false
    },
    {
      "description": "LiteLLM image updates require manual review while local monkey patches are active",
      "matchDatasources": ["docker"],
      "matchDepNames": ["berriai/litellm"],
      "matchPackageNames": ["berriai/litellm", "ghcr.io/berriai/litellm"],
      "matchPaths": ["kubernetes/apps/apps/ai/litellm/helmrelease.yaml"],
      "automerge": false,
      "platformAutomerge": false
    }
  ],

  "customManagers": [
    {
      "description": "Track tags with static -openvino suffix (strips suffix for version lookup, re-appends on update)",
      "customType": "regex",
      "fileMatch": ["\\.ya?ml$"],
      "packageNameTemplate": "{{{depName}}}",
      "matchStrings": [
        "(?:^|\\r?\\n)\\s*#\\s*renovate:\\s*datasource=(?<datasource>\\S+)\\s+depName=(?<depName>\\S+)(?:\\s+registryUrl=(?<registryUrl>\\S+))?\\s*\\r?\\n\\s*repository:\\s*(?<packageName>\\S+)\\s*\\r?\\n\\s*tag:\\s*[\"']?(?<currentValue>[^\"'\\s]+)-openvino[\"']?"
      ],
      "autoReplaceStringTemplate": "tag: {{{newValue}}}-openvino"
    },
    {
      "description": "Enable # renovate: datasource=... comments (repo/tag directly below)",
      "customType": "regex",
      "fileMatch": ["\\.ya?ml$"],
      "packageNameTemplate": "{{{depName}}}",
      "matchStrings": [
        "(?:^|\\r?\\n)\\s*#\\s*renovate:\\s*datasource=(?<datasource>\\S+)\\s+depName=(?<depName>\\S+)(?:\\s+registryUrl=(?<registryUrl>\\S+))?\\s*\\r?\\n\\s*repository:\\s*(?<packageName>\\S+)\\s*\\r?\\n\\s*tag:\\s*[\"']?(?<currentValue>[^\"'\\s]+)[\"']?"
      ]
    },
    {
      "description": "Track Helm chart versions",
      "customType": "regex",
      "fileMatch": [
        "kubernetes/.*/helmrelease\\.ya?ml$",
        "kubernetes/components/bjw-s-defaults/kustomization\\.ya?ml$"
      ],
      "matchStrings": [
        "(?:^|\\r?\\n)\\s*#\\s*renovate:\\s*datasource=(?<datasource>\\S+)\\s+depName=(?<depName>\\S+)\\s+registryUrl=(?<registryUrl>\\S+)\\s*\\r?\\n\\s*(?:version|value):\\s*[\"']?(?<currentValue>[^\"'\\s]+)[\"']?"
      ]
    }
  ]
}
