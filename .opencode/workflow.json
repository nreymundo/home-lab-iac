{
  "verify": "pre-commit run --all-files && checkov --config-file .checkov.yaml && scripts/validate-terraform.sh && scripts/validate-packer.sh",
  "review_required": true,
  "max_cycles": 3,
  "security_patterns": [
    "**/*.env",
    "**/*.env.*",
    "**/*.key",
    "**/*.p12",
    "**/*.pem",
    "**/*.pfx",
    "**/*.sops.yaml",
    "**/*.sops.yml",
    "**/*.agekey",
    "**/*.tf",
    "**/.github/workflows/**",
    "**/.vault*",
    "**/*credential*",
    "**/Dockerfile*",
    "**/acl*",
    "**/auth/**",
    "**/authentication/**",
    "**/cookie*",
    "**/credentials*",
    "**/csrf*",
    "**/docker-compose*.y*ml",
    "**/jwt*",
    "**/middleware/**",
    "**/migrations/**",
    "**/passport*",
    "**/permissions*",
    "**/query*",
    "**/rbac*",
    "**/security/**",
    "**/seed*.sql",
    "**/session*",
    "**/sql**",
    "ansible/inventories/**/group_vars/**",
    "ansible/inventories/**/host_vars/**",
    "ansible/secrets/**",
    "kubernetes/**/auth*.yaml",
    "kubernetes/**/certificate*.yaml",
    "kubernetes/**/identity/**",
    "kubernetes/**/secret*.yaml",
    "kubernetes/**/tls*.yaml",
    "local/**",
    "packer/**/*.auto.pkrvars.hcl",
    "packer/**/*.pkrvars.hcl",
    "packer/**/http/*.cfg",
    "packer/**/http/user-data",
    ".checkov.yaml",
    ".pre-commit-config.yaml",
    ".sops.yaml"
  ]
}
