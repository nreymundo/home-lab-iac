{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "generalist",
  "subagent_depth": 1,
  "instructions": ["AGENTS.md"],
  "mcp": {
    "jcodemunch": {
      "type": "local",
      "command": [
        "/bin/sh",
        "-c",
        "exec env CODE_INDEX_PATH=\"${XDG_DATA_HOME:-$HOME/.local/share}/jcodemunch\" uvx --from jcodemunch-mcp==1.108.144 jcodemunch-mcp"
      ],
      "enabled": true,
      "timeout": 30000
    }
  },
  "agent": {
    "build": { "disable": true },
    "general": { "disable": true }
  },
  "permission": {
    "edit": { "*": "allow" },
    "bash": {
      "*": "allow",
      "kubectl *": "ask",
      "helm install *": "ask",
      "helm upgrade *": "ask",
      "helm uninstall *": "ask",
      "helm rollback *": "ask",
      "terraform apply*": "ask",
      "terraform destroy*": "ask",
      "terraform import*": "ask",
      "terraform state*": "ask",
      "tofu apply*": "ask",
      "tofu destroy*": "ask",
      "tofu import*": "ask",
      "tofu state*": "ask",
      "flux reconcile*": "ask",
      "flux suspend*": "ask",
      "flux resume*": "ask",
      "flux bootstrap*": "ask",
      "flux uninstall*": "ask",
      "ansible-playbook *": "ask",
      "ansible-galaxy*": "ask",
      "k3d *": "ask",
      "opencode debug config*": "deny"
    }
  }
}
