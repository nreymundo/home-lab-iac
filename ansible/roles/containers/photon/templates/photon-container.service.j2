[Unit]
Description=Photon geocoder container
Wants=network-online.target
After=network-online.target docker.service
Requires=docker.service

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory={{ photon_base_dir }}
ExecStart=/usr/bin/docker compose -p {{ photon_compose_project_name }} -f {{ photon_compose_file }} up -d --remove-orphans
ExecStop=/usr/bin/docker compose -p {{ photon_compose_project_name }} -f {{ photon_compose_file }} down
TimeoutStartSec=0
TimeoutStopSec=120s

[Install]
WantedBy=multi-user.target
