[Unit]
Description=NetBird Docker Compose stack
Requires=docker.service
After=docker.service network-online.target
Wants=network-online.target

[Service]
Type=oneshot
RemainAfterExit=true
WorkingDirectory={{ netbird_base_dir }}
ExecStart=/usr/bin/docker compose -p netbird -f {{ netbird_compose_file }} up -d --remove-orphans
ExecStop=/usr/bin/docker compose -p netbird -f {{ netbird_compose_file }} down

[Install]
WantedBy=multi-user.target
